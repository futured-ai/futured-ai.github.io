<div class="container card">
  {% if include.title %}
    <h1 class="pffbold">{{ include.title }}</h1>
  {% endif %}
  <div class="badge-row">
    {% if include.location %}
      {% include badge.liquid img="pin" text="Computer Science Department, UoC" %}
    {% endif %}
    {% if include.when %}
      {% include badge.liquid img="calendar" text=include.when %}
    {% endif %}
  </div>
  <p class="tag">{{ include.tag }}</p>
  <p>{{ include.text }}</p>
  <!--
    <div class="page-buttons">
      <a href="https://forms.gle/3fAafWCyVxya5jf6A" class="btn primary">Apply&nbsp;here</a>
    </div>
  -->
</div>
